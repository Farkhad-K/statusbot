# Copy this file to .env and fill in real values.

# ── Telegram ──────────────────────────────────────────────────────────────
# Get your token from @BotFather after creating a bot
BOT_TOKEN=token_from_botfather

# Your Telegram user ID (get it from @userinfobot)
ALLOWED_IDS=512374891,748291034

# ── Q1 · Questionary v1 ───────────────────────────────────────────────────
Q1_DSN=connection_string_for_questionary_v1
Q1_TABLE=questionnaires

# ── Q2 · Questionary v2 ───────────────────────────────────────────────────
Q2_DSN=connection_string_for_questionary_v2
Q2_TABLE=questionnaires

# ── K · Collaboration v2 ──────────────────────────────────────────────────
K_DSN=connection_string_for_collaboration_v2
K_TABLE=contracts

# ── SQL Sandbox (future feature — not active yet) ─────────────────────────
# Comma-separated Telegram user IDs who can use the SQL Sandbox.
# Can be a subset of ALLOWED_IDS or a completely separate list.
# Leave empty or omit to disable the feature entirely.
# SQL_ALLOWED_IDS=512374891

# DSN for the sandbox database — point at a READ-ONLY Postgres role.
# SQL_DSN=postgresql://readonly_user:password@host:5432/dbname
